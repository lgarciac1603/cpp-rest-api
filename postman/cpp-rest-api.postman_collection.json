  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User (dynamic)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now().toString();",
                  "pm.collectionVariables.set('testUsername', 'user' + suffix);",
                  "pm.collectionVariables.set('testEmail', 'user' + suffix + '@example.com');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{testUsername}}",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "{{testEmail}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            }
          },
          "response": []
        },
